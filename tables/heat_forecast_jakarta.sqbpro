    adm4 TEXT NOT NULL,
    desa_kelurahan TEXT,
    kecamatan TEXT,
    kotkab TEXT,
    provinsi TEXT,
    latitude REAL,
    longitude REAL,
    timezone TEXT,
    local_datetime TEXT NOT NULL,
    temperature_c REAL NOT NULL,
    humidity_pct REAL NOT NULL,
    heat_index_c REAL,
    risk_level TEXT,
    weather_desc_en TEXT,
    analysis_date TEXT,
    PRIMARY KEY (adm4, local_datetime)
);</sql><current_tab id="0"/></tab_sql></sqlb_project>
